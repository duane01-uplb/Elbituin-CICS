# FuelBridge Frontend Environment Variables
# Copy this to .env.local

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Map defaults (centered on Laguna/Metro Manila border)
NEXT_PUBLIC_MAP_CENTER_LAT=14.4292
NEXT_PUBLIC_MAP_CENTER_LNG=121.0603

# Supabase (optional for frontend auth)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
